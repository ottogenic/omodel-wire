#!/usr/bin/env bash
# new-worktree — create, clean up, or abort an isolated git worktree, so an agent
# (or you) never shares a working tree with anyone else. See AGENTS.md.
#
#   create:  ./new-worktree <folder> <branch>       -> ../<folder> on a new <branch>
#            e.g.  ./new-worktree omw-thingy feat/123
#   clean:   ./new-worktree --delete <folder>        (aliases: --undo, --rm)
#            remove ../<folder> + its LOCAL branch only. SAFE: never touches an open
#            PR or the remote branch, so a submitted-but-unmerged PR lives on. Use
#            this to free the folder once your PR is up (or after it merged).
#   abort:   ./new-worktree --abort <folder>
#            the throw-it-all-away version — ALSO closes the open PR + deletes the
#            remote branch. Use when abandoning the feature entirely.
#            (-y skips the confirmation prompt in either mode.)
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Not inside a git repository." >&2; exit 1; }

usage() {
  cat <<'EOF'
new-worktree — make or remove an isolated worktree (own folder + own branch).

  create:  ./new-worktree <folder> <branch>
           e.g.  ./new-worktree omw-thingy feat/123
  clean:   ./new-worktree --delete <folder>   (aliases: --undo, --rm; -y skips prompt)
           removes ../<folder> + its LOCAL branch only. SAFE: leaves any open PR and
           the remote branch alone, so a pending PR (or a merged one) is untouched.
  abort:   ./new-worktree --abort <folder>
           also CLOSES the open PR + deletes the remote branch — for abandoning a feature.

Worktrees are siblings of this repo. `git worktree list` shows them all.
EOF
}

# ---- parse args -------------------------------------------------------------
ASSUME_YES=0; MODE=""; A1=""
for a in "$@"; do
  case "$a" in
    -y|--yes)                 ASSUME_YES=1 ;;
    --delete|--undo|--rm|-d)  MODE="delete" ;;
    --abort)                  MODE="abort" ;;
    -h|--help)                usage; exit 0 ;;
    -*)                       echo "unknown flag: $a" >&2; usage >&2; exit 1 ;;
    *)  if [ -z "${A1:-}" ]; then A1="$a"; elif [ -z "${A2:-}" ]; then A2="$a"; fi ;;
  esac
done
if [ -z "$MODE" ] && [ -n "${A1:-}" ] && [ -n "${A2:-}" ]; then MODE="create"; fi
if { [ "$MODE" = "create" ] && { [ -z "${A1:-}" ] || [ -z "${A2:-}" ]; }; } \
   || { { [ "$MODE" = "delete" ] || [ "$MODE" = "abort" ]; } && [ -z "${A1:-}" ]; } \
   || [ -z "$MODE" ]; then
  usage; exit 0
fi

confirm() {  # confirm "question" -> 0 if yes
  [ "$ASSUME_YES" = 1 ] && return 0
  if [ ! -t 0 ]; then echo "  (non-interactive; pass -y to proceed) — skipped: $1" >&2; return 1; fi
  printf '%s [y/N] ' "$1"; read -r ans; [ "$ans" = y ] || [ "$ans" = Y ]
}

# ---- delete / abort ---------------------------------------------------------
if [ "$MODE" = "delete" ] || [ "$MODE" = "abort" ]; then
  folder="$(basename "$A1")"           # accept a name or a path
  target_path=""; target_branch=""; cur=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) cur="${line#worktree }"
                    [ "$(basename "$cur")" = "$folder" ] && { target_path="$cur"; target_branch=""; } ;;
      "branch "*)   [ -n "$target_path" ] && [ "$cur" = "$target_path" ] && target_branch="${line#branch refs/heads/}" ;;
    esac
  done < <(git worktree list --porcelain)

  if [ -z "$target_path" ]; then
    echo "No worktree named '$folder'. Current worktrees:" >&2
    git worktree list >&2; exit 1
  fi
  if [ "$(git rev-parse --show-toplevel)" = "$target_path" ]; then
    echo "You're inside '$folder' — cd out first (e.g. cd '$repo_root'), then rerun." >&2; exit 1
  fi

  pr=""; remote_branch=0
  if [ -n "$target_branch" ]; then
    if git ls-remote --exit-code --heads origin "$target_branch" >/dev/null 2>&1; then remote_branch=1; fi
    if command -v gh >/dev/null 2>&1; then
      pr="$(gh pr list --head "$target_branch" --state open --json number --jq '.[0].number // empty' 2>/dev/null || true)"
    fi
  fi

  echo "About to remove:"
  echo "  worktree:      $target_path"
  [ -n "$target_branch" ] && echo "  local branch:  $target_branch"
  if [ "$MODE" = "abort" ]; then
    [ -n "$pr" ]                                   && echo "  PR #$pr        -> WILL BE CLOSED"
    { [ "$remote_branch" = 1 ] && [ -z "$pr" ]; }  && echo "  origin/$target_branch -> WILL BE DELETED"
  else
    [ -n "$pr" ]           && echo "  PR #$pr (open) -> KEPT (use --abort to close it)"
    [ "$remote_branch" = 1 ] && echo "  origin/$target_branch -> KEPT"
  fi
  confirm "Proceed?" || { echo "aborted."; exit 0; }

  git worktree remove --force "$target_path" && echo "✓ removed worktree"
  if [ -n "$target_branch" ] && git show-ref --verify --quiet "refs/heads/$target_branch"; then
    git branch -D "$target_branch" >/dev/null && echo "✓ deleted local branch $target_branch"
  fi

  if [ "$MODE" = "abort" ]; then
    if [ -n "$pr" ]; then
      gh pr close "$pr" --delete-branch && echo "✓ closed PR #$pr + deleted remote branch"
    elif [ "$remote_branch" = 1 ]; then
      git push origin --delete "$target_branch" && echo "✓ deleted remote branch origin/$target_branch"
    fi
  else
    [ -n "$pr" ] && echo "ℹ PR #$pr is still open and origin/$target_branch is intact — your PR lives on."
    { [ -z "$pr" ] && [ "$remote_branch" = 1 ]; } && \
      echo "ℹ origin/$target_branch still exists — delete it with 'git push origin --delete $target_branch', or use --abort."
  fi
  echo "done."
  exit 0
fi

# ---- create -----------------------------------------------------------------
folder="$A1"; branch="$A2"
dest="$(dirname "$repo_root")/$folder"
if [ -e "$dest" ]; then echo "Refusing: '$dest' already exists." >&2; exit 1; fi

echo "Fetching origin..."
git fetch --quiet origin || echo "(fetch failed — falling back to local refs)"
base="origin/main"
git rev-parse --verify --quiet "$base" >/dev/null || base="main"

if git show-ref --verify --quiet "refs/heads/$branch"; then
  echo "Branch '$branch' already exists — checking it out in the new worktree."
  git worktree add "$dest" "$branch"
else
  echo "Creating branch '$branch' from $base."
  git worktree add -b "$branch" "$dest" "$base"
fi

cat <<EOF

✓ Worktree ready:  $dest
  branch:          $branch
  Point your agent's working directory here. When finished:
     ./new-worktree --delete $folder    # free the folder, keep any PR
     ./new-worktree --abort  $folder    # or throw it all away (closes the PR)
EOF
